{
  "name": "ticketbot",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "deploy:vm": "bash scripts/deploy-vm.sh",
    "deploy:vm:smoke": "bash scripts/tests/deploy-vm-smoke.sh",
